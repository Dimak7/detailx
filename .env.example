# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database
# Production: set DATABASE_URL to a PostgreSQL connection string.
# If omitted, bookings are saved to data/bookings.json for local development.
DATABASE_URL=
DATABASE_SSL=false

# Email confirmations through Resend
# Create an API key in Resend and use a verified sender/domain for BOOKING_FROM_EMAIL.
RESEND_API_KEY=
BOOKING_FROM_EMAIL="DETAILX Chicago <bookings@yourdomain.com>"
BOOKING_ADMIN_EMAIL=book@detailxchicago.com

# Optional SMS confirmations through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
