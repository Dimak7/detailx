# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database
# Production: set DATABASE_URL to a PostgreSQL connection string.
# If omitted, bookings are saved to data/bookings.json for local development.
DATABASE_URL=
DATABASE_SSL=false

# Email confirmations through Resend
# EMAIL_FROM must use a verified Resend sender/domain.
EMAIL_API_KEY=
EMAIL_FROM="DETAILX Chicago <sales@detailxchicago.com>"
BUSINESS_EMAIL=sales@detailxchicago.com

# Optional SMS confirmations through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
