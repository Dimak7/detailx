# App
NEXT_PUBLIC_SITE_URL=https://detailxchicago.com

# Database
# Production: set DATABASE_URL to a PostgreSQL connection string.
# If omitted, bookings are saved to data/bookings.json for local development.
DATABASE_URL=
DATABASE_SSL=false

# Admin schedule manager
# Used at /admin/schedule. Choose a long private value.
ADMIN_SCHEDULE_KEY=

# Email confirmations through Resend
# EMAIL_FROM must use a verified Resend sender/domain.
RESEND_API_KEY=
BUSINESS_EMAIL=sales@detailxchicago.com
EMAIL_FROM=bookings@detailxchicago.com
RESEND_FROM_EMAIL=bookings@detailxchicago.com

# Optional SMS confirmations through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional Telegram admin booking notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
