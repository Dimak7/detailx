# App
NEXT_PUBLIC_SITE_URL=https://detailxchicago.com

# Database
# Production: required. Set DATABASE_URL to a PostgreSQL connection string.
# If omitted in local development only, data falls back to data/*.json and will not persist across deploys.
DATABASE_URL=
DATABASE_SSL=false

# Admin portal
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Legacy API key fallback for /api/admin/schedule. Choose a long private value if used.
ADMIN_SCHEDULE_KEY=

# Email confirmations through Resend
# EMAIL_FROM must use a verified Resend sender/domain.
RESEND_API_KEY=
BUSINESS_EMAIL=sales@detailxchicago.com
EMAIL_FROM=bookings@detailxchicago.com
RESEND_FROM_EMAIL=bookings@detailxchicago.com

# Optional SMS confirmations through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional Telegram admin booking notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Stripe hosted payment links for admin invoices
STRIPE_SECRET_KEY=
